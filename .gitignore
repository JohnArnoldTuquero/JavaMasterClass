.idea/
*.iml
*.iws
*.ipr

# 4. Visual Studio Code Configuration
.vscode/
.history/
*.code-workspace

# 5. Eclipse IDE Files
.metadata/
.classpath
.project
.settings/
*.launch

# 6. Operating System Trash Files
Thumbs.db
.DS_Store
.DS_Store?
ehthumbs.db
[Dd]esktop.ini

